#!/usr/bin/env python3
"""opencode-dashboard — wraps `opencode run --format json` and forwards events to the dashboard.
Usage: opencode-dashboard [--model provider/model] [--no-skip-perms] [message...]
Env:   CLAUDE_DASHBOARD_URL, OPENCODE_MODEL
"""
import sys, os, json, subprocess, urllib.request, uuid, time

DASHBOARD_URL = os.environ.get("CLAUDE_DASHBOARD_URL", "http://localhost:3456")
MODEL = os.environ.get("OPENCODE_MODEL", "opencode/gpt-5-nano")
SKIP_PERMS = True
ARGS = []

i = 1
while i < len(sys.argv):
    if sys.argv[i] == "--model" and i + 1 < len(sys.argv):
        MODEL = sys.argv[i + 1]; i += 2
    elif sys.argv[i] == "--no-skip-perms":
        SKIP_PERMS = False; i += 1
    else:
        ARGS.append(sys.argv[i]); i += 1

MESSAGE = " ".join(ARGS)
SESSION_ID = f"opencode-{int(time.time())}-{os.getpid()}"
TRANSCRIPT_PATH = "/root/.local/share/opencode/"

TOOL_NAME_MAP = {
    "bash": "Bash", "read": "Read", "write": "Write", "edit": "Edit",
    "grep": "Grep", "glob": "Glob", "webfetch": "WebFetch",
    "websearch": "WebSearch", "task": "Task", "todoread": "TodoRead",
    "todowrite": "TodoWrite",
}

def post(event):
    event.setdefault("_source", "opencode")
    event.setdefault("transcript_path", TRANSCRIPT_PATH)
    body = json.dumps(event).encode()
    req = urllib.request.Request(
        f"{DASHBOARD_URL}/api/events", data=body,
        headers={"Content-Type": "application/json"}, method="POST"
    )
    try:
        urllib.request.urlopen(req, timeout=5)
    except Exception:
        pass

# ── SessionStart ──────────────────────────────────────────────────────────────
post({"hook_event_name": "SessionStart", "session_id": SESSION_ID,
      "source": "opencode-dashboard", "model": MODEL})

# ── UserPromptSubmit ──────────────────────────────────────────────────────────
if MESSAGE:
    post({"hook_event_name": "UserPromptSubmit", "session_id": SESSION_ID,
          "prompt": MESSAGE})

# ── Run opencode ──────────────────────────────────────────────────────────────
cmd = ["opencode", "run", "--model", MODEL, "--format", "json"]
if SKIP_PERMS:
    cmd.append("--dangerously-skip-permissions")
if ARGS:
    cmd += ARGS

proc = subprocess.Popen(cmd, stdout=subprocess.PIPE, stderr=subprocess.DEVNULL,
                        text=True, bufsize=1)

last_text = ""
for line in proc.stdout:
    line = line.strip()
    if not line:
        continue
    try:
        evt = json.loads(line)
    except Exception:
        continue

    etype = evt.get("type", "")
    part = evt.get("part", {})

    if etype == "tool_use":
        tool = part.get("tool", "unknown")
        state = part.get("state", {})
        status = state.get("status", "")
        inp = state.get("input", {})
        tool_name = TOOL_NAME_MAP.get(tool.lower(), tool)

        # PreToolUse (reconstructed from completed data)
        post({"hook_event_name": "PreToolUse", "session_id": SESSION_ID,
              "tool_name": tool_name, "tool_input": inp})

        if status == "completed":
            post({"hook_event_name": "PostToolUse", "session_id": SESSION_ID,
                  "tool_name": tool_name, "tool_input": inp,
                  "tool_response": state.get("output", "")})
        else:
            post({"hook_event_name": "PostToolUseFailure", "session_id": SESSION_ID,
                  "tool_name": tool_name, "tool_input": inp,
                  "error": state.get("error", f"status={status}")})

    elif etype == "text":
        last_text = part.get("text", last_text)

proc.wait()

# ── Stop ──────────────────────────────────────────────────────────────────────
post({"hook_event_name": "Stop", "session_id": SESSION_ID,
      "last_assistant_message": last_text})

# ── SessionEnd ────────────────────────────────────────────────────────────────
post({"hook_event_name": "SessionEnd", "session_id": SESSION_ID})
